# BlackRoad OS — RoadChain Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ────────────────────────────────────────────────────────────────
# BlackRoad Contributor Gateway (REQUIRED)
# Obtain your token at https://gateway.blackroad.io or by emailing
# blackroad.systems@gmail.com with subject:
#   "Contributor Token Request — <your GitHub username>"
# ────────────────────────────────────────────────────────────────
BLACKROAD_GATEWAY_TOKEN=
BLACKROAD_GATEWAY_URL=https://gateway.blackroad.io

# Gateway server port (local development)
GATEWAY_PORT=4000

# ────────────────────────────────────────────────────────────────
# Stripe (Payments & Contributor Subscriptions)
# https://dashboard.stripe.com/apikeys
# ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ────────────────────────────────────────────────────────────────
# Dashboard API Server
# ────────────────────────────────────────────────────────────────
API_PORT=3000
DASHBOARD_PORT=3142

# ────────────────────────────────────────────────────────────────
# Bitcoin Wallet Monitor
# ────────────────────────────────────────────────────────────────
WALLET_ADDRESS=1Ak2fc5N2q4imYxqVMqBNEQDFq8J2Zs9TZ
BLOCKCHAIN_API_URL=https://blockstream.info/api

# ────────────────────────────────────────────────────────────────
# Cloudflare (Deployment & Tunnel)
# ────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# ────────────────────────────────────────────────────────────────
# Tailscale (Private Network)
# ────────────────────────────────────────────────────────────────
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# ────────────────────────────────────────────────────────────────
# Node environment
# ────────────────────────────────────────────────────────────────
NODE_ENV=development
